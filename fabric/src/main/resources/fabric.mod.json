{
  "schemaVersion": 1,
  "id": "antixray",
  "version": "${modVersion}",
  "name": "CabalAntiXRay",
  "description": "Fabric-only, performance-oriented anti-xray for Cabal servers. Targets Minecraft 26.2-snapshot-3.",
  "authors": [
    "Drex",
    "ohnodev"
  ],
  "contact": {
    "sources": "https://github.com/ohnodev/CabalAntiXRay"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "me.drex.antixray.fabric.AntiXrayMod"
    ]
  },
  "mixins": [
    "antixray.common.mixins.json",
    "antixray.fabric.mixins.json"
  ],
  "accessWidener": "antixray.accesswidener",
  "depends": {
    "fabricloader": ">=0.19.1",
    "fabric-api": ">=0.145.5",
    "minecraft": "26.2-snapshot-3",
    "java": ">=25"
  }
